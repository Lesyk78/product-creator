# --- Auth ---
# Basic auth credentials (browser will prompt). Use strong password.
AUTH_USER=oles
AUTH_PASSWORD=change-me-strong-password

# Comma-separated list of allowed IPs/CIDRs. Empty = allow all (NOT recommended for prod).
# Example: 192.168.1.0/24,46.224.91.63,2a01:....::/64
ALLOWED_IPS=

# Trust X-Forwarded-For from reverse proxy (Coolify Traefik sets this). Set to 1 behind proxy.
TRUST_PROXY=1

# --- Odoo PROD ---
ODOO_URL=https://odoo.boni.tools
ODOO_DB=boni-brands-boni-odoo-prod-16259222
ODOO_LOGIN=oles.dzhyhryniuk@boni-brands.com
ODOO_PASSWORD=

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# --- Bitrix24 alerts ---
BITRIX_WEBHOOK=https://boni.team/rest/107/x25sj3ejw9vo88b7
ALERT_RESPONSIBLE_ID=310

# --- App ---
LOG_LEVEL=info
